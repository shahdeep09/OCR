# BookScan frontend env. Copy to `.env.local` (which Vite reads automatically
# and which is gitignored) and edit BACKEND_URL.

# Public URL of the backend. Default points at a local uvicorn.
# For RunPod, paste the pod's public 8000 URL here, e.g.:
#   VITE_BACKEND_URL=https://abcdef-8000.proxy.runpod.net
VITE_BACKEND_URL=http://127.0.0.1:8000
