# BookScan backend env overrides.
# Copy to .env on your deployment, edit, then `source .env` (or use python-dotenv
# / runpod env vars). Nothing is required — every key has a sensible default.

# CORS — comma-separated list of allowed origins. Empty / unset = open ("*").
# Tighten this once your frontend is on a known URL.
# BOOKSCAN_CORS_ORIGINS=https://my-pc.example,https://other-pc.example

# Device control. Auto-policy: Windows → CPU (avoids meta-tensor bug),
# Linux → whatever torch decides (GPU on RunPod).
# Set BOOKSCAN_FORCE_CPU=1 to pin CPU everywhere. Set BOOKSCAN_FORCE_GPU=1 to
# clear CPU pins on Windows (use only if you know your torch+CUDA combo works).
# BOOKSCAN_FORCE_CPU=1
# BOOKSCAN_FORCE_GPU=1

# Llama-server binary. Auto-detected from backend/llamacpp/ on Windows;
# set explicitly on Linux/RunPod after `pip install llama-cpp-python` builds it.
# LLAMA_CPP_BINARY=/usr/local/bin/llama-server
